#!/bin/bash

TOKEN="$token"
ENDPOINT="https://$ENDPOINT"
BUCKET="$BUCKET"
OBJECT_KEY="my-big-file.zip"
FILE_PATH="/path/to/my-big-file.zip"

# 1) Initier le multipart upload
INIT_XML=$(curl -s -X POST \
  "${ENDPOINT}/${BUCKET}/${OBJECT_KEY}?uploads" \
  -H "Authorization: Bearer ${TOKEN}")

echo "Init response:"
echo "$INIT_XML"

UPLOAD_ID=$(echo "$INIT_XML" | xmllint --xpath 'string(//*[local-name()="UploadId"])' - 2>/dev/null)

if [[ -z "$UPLOAD_ID" ]]; then
  echo "Impossible de récupérer UploadId"
  exit 1
fi

echo "UploadId: $UPLOAD_ID"

# 2) Exemple : upload d'une seule part
# Pour un vrai gros fichier, il faut le découper en plusieurs morceaux
ETAG_1=$(curl -s -D - -o /dev/null -X PUT \
  "${ENDPOINT}/${BUCKET}/${OBJECT_KEY}?partNumber=1&uploadId=${UPLOAD_ID}" \
  -H "Authorization: Bearer ${TOKEN}" \
  --data-binary @"$FILE_PATH" \
  | awk -F': ' '/ETag/ {gsub("\r","",$2); print $2}')

echo "ETag part 1: $ETAG_1"

# 3) Finaliser le multipart upload
cat > complete.xml <<EOF
<CompleteMultipartUpload>
  <Part>
    <PartNumber>1</PartNumber>
    <ETag>${ETAG_1}</ETag>
  </Part>
</CompleteMultipartUpload>
EOF

COMPLETE_RESP=$(curl -s -X POST \
  "${ENDPOINT}/${BUCKET}/${OBJECT_KEY}?uploadId=${UPLOAD_ID}" \
  -H "Authorization: Bearer ${TOKEN}" \
  -H "Content-Type: application/xml" \
  --data-binary @complete.xml)

echo "Complete response:"
echo "$COMPLETE_RESP"