import logging

import requests

from cos_service.services.ibm_endpoints import get_cos_control_endpoint

logger = logging.getLogger(__name__)

REQUEST_TIMEOUT_SECONDS = 30


def list_recovery_ranges(backup_vault_name: str, access_token: str) -> list:
    """
    List all recovery ranges available on a backup vault.

    IBM COS: GET {cos_control_endpoint}/backup_vaults/{backup_vault_name}/recovery_ranges
    """
    url = f"{get_cos_control_endpoint()}/backup_vaults/{backup_vault_name}/recovery_ranges"
    headers = {
        "Authorization": f"Bearer {access_token}",
        "Accept": "application/json",
    }

    recovery_ranges: list = []
    next_token: str | None = None

    while True:
        params = {"token": next_token} if next_token else None
        response = requests.get(url, headers=headers, params=params, timeout=REQUEST_TIMEOUT_SECONDS)
        response.raise_for_status()
        body = response.json()

        recovery_ranges.extend(body.get("recovery_ranges", []))

        next_token = body.get("next", {}).get("token") if isinstance(body.get("next"), dict) else None
        if not next_token:
            break

    return recovery_ranges


def start_restore_from_recovery_range(
        backup_vault_name: str,
        restore_payload: dict,
        access_token: str,
) -> dict:
    """
    Initiate an in-place restore on a backup vault from a given recovery range.

    IBM COS: POST {cos_control_endpoint}/backup_vaults/{backup_vault_name}/restore

    restore_payload must contain:
        - recovery_range_id: str
        - restore_point_in_time: ISO-8601 timestamp (within the recovery range window)
        - restore_type: "in_place"
        - target_resource_crn: CRN of the destination bucket
    """
    url = f"{get_cos_control_endpoint()}/backup_vaults/{backup_vault_name}/restore"
    headers = {
        "Authorization": f"Bearer {access_token}",
        "Content-Type": "application/json",
        "Accept": "application/json",
    }

    response = requests.post(url, headers=headers, json=restore_payload, timeout=REQUEST_TIMEOUT_SECONDS)
    response.raise_for_status()
    return response.json()
