import logging
import re

from pydantic import Field

logger = logging.getLogger(__name__)


# "payload": {"backup_vault_name": "my-backup-vault"}
#    {
#        "product_branch": "main",
#        "payload": {"backup_vault_name": "my-backup-vault"}
#    }

BACKUP_VAULT_NAME_PATTERN = re.compile(
    r"(?!^((25[0-5]|(2[0-4]|1\d|[1-9])\d)\.?\b){4}$)(^[a-z0-9][a-z0-9\-\.]{1,61}[a-z0-9]$)"
)


class BucketRestoreBackupVaultPayload(ProductActionPayload):
    backup_vault_name: str = Field(min_length=3, max_length=63)


@product_action("cos.bucket.v1.restore_backup_vault", tags=["cos"],
                payload=BucketRestoreBackupVaultPayload, config=ProductActionConfig(
        lock_subscription_on_failure=True
    ))
def bucket_restore_backup_vault():
    @step
    def validate_bucket(
            payload: BucketRestoreBackupVaultPayload = depends(payload_dependency),
            session: SASession = depends(sqlalchemy_session_dependency)
    ) -> dict:
        from cos_service.services.bucketService import get_bucket_by_sub_id

        bucket = get_bucket_by_sub_id(session, payload.subscription_id)
        if bucket is None or not bucket["name"]:
            raise DeclineDemandException(
                f"the bucket doesn't exist or not fully created for the sub id, {payload.subscription_id}")
        if bucket["clean_status"] == Status.INPROGRESS.value:
            raise DeclineDemandException(
                "A clean bucket operation is already ongoing. Restore cannot be started meanwhile.")
        if bucket.get("restore_status") == Status.INPROGRESS.value:
            raise DeclineDemandException(
                "A restore operation is already in progress for this bucket.")

        return bucket

    @step
    def validate_backup_vault(
            bucket: dict,
            payload: BucketRestoreBackupVaultPayload = depends(payload_dependency),
            session: SASession = depends(sqlalchemy_session_dependency)
    ) -> dict:
        from cos_service.services.backupVaultService import get_backup_vault_by_name

        if not BACKUP_VAULT_NAME_PATTERN.fullmatch(payload.backup_vault_name):
            raise DeclineDemandException(
                f"Invalid backup_vault_name '{payload.backup_vault_name}'. "
                "Must be 3-63 chars, lowercase alphanumeric with '.' or '-', "
                "and cannot be IP-formatted.")

        backup_vault = get_backup_vault_by_name(
            payload.backup_vault_name, bucket["subscription_id"], session)
        if backup_vault is None:
            raise DeclineDemandException(
                f"Backup vault '{payload.backup_vault_name}' does not exist for this subscription.")
        if backup_vault["subscription_id"] != bucket["subscription_id"]:
            raise DeclineDemandException(
                f"Backup vault '{payload.backup_vault_name}' is not linked to this bucket.")
        if backup_vault["status"] != Status.ACTIVE.value:
            raise DeclineDemandException(
                f"Backup vault '{payload.backup_vault_name}' is not active "
                f"(status={backup_vault['status']}).")

        return backup_vault

    @step
    def get_cos_api_key(
            bucket: dict,
            backup_vault: dict,
            vault: Vault = depends(vault_dependency)
    ) -> str:
        from cos_service.services.vault_service import get_cos_api_key

        try:
            return get_cos_api_key(bucket, vault)

        except Exception as e:
            raise e

    @step
    def get_latest_recovery_range(
            backup_vault: dict,
            api_key: str,
    ) -> dict:
        from cos_service.services.ibm_iam_service import get_iam_access_token
        from cos_service.services.backupVaultService import list_recovery_ranges

        try:
            access_token = get_iam_access_token(api_key)

            recovery_ranges = list_recovery_ranges(backup_vault["name"], access_token)
            if not recovery_ranges:
                raise DeclineDemandException(
                    f"No recovery range available on backup vault '{backup_vault['name']}'.")

            latest_recovery_range = max(
                recovery_ranges, key=lambda r: r["range_end_time"])

            if latest_recovery_range.get("status") and latest_recovery_range["status"] != Status.AVAILABLE.value:
                raise DeclineDemandException(
                    f"Latest recovery range '{latest_recovery_range['recovery_range_id']}' is not available "
                    f"for restore (status={latest_recovery_range['status']}).")

            return latest_recovery_range
        except DeclineDemandException:
            raise
        except Exception as e:
            raise e

    @step
    def initiate_restore(
            bucket: dict,
            backup_vault: dict,
            recovery_range: dict,
            api_key: str,
    ) -> dict:
        from cos_service.services.ibm_iam_service import get_iam_access_token
        from cos_service.services.backupVaultService import start_restore_from_recovery_range

        try:
            access_token = get_iam_access_token(api_key)

            restore_payload = {
                "recovery_range_id": recovery_range["recovery_range_id"],
                "restore_point_in_time": recovery_range["range_end_time"],
                "restore_type": "in_place",
                "target_resource_crn": bucket["crn"],
            }

            restore_job = start_restore_from_recovery_range(
                backup_vault["name"], restore_payload, access_token)

            return restore_job
        except Exception as e:
            raise e

    @step
    def save_restore_job_in_db(
            restore_job: dict,
            bucket: dict,
            backup_vault: dict,
            recovery_range: dict,
            payload: BucketRestoreBackupVaultPayload = depends(payload_dependency),
            state_manager: StateManager = depends(state_manager_dependency),
            session: SASession = depends(sqlalchemy_session_dependency)
    ) -> None:
        from cos_service.services.backupVaultService import record_restore_job, get_restore_jobs_by_bucket_sub_id

        try:

            record_restore_job(bucket, backup_vault["id"],
                               recovery_range["recovery_range_id"],
                               restore_job["restore_id"],
                               recovery_range["range_end_time"],
                               payload.requester, session)
            restore_jobs = get_restore_jobs_by_bucket_sub_id(bucket["subscription_id"], session)
            restore_jobs_to_dict = [{"restore_job_id": job["restore_job_id"],
                                     "backup_vault_id": job["backup_vault_id"],
                                     "recovery_range_id": job["recovery_range_id"],
                                     "restore_point_in_time": job["restore_point_in_time"],
                                     "status": job["status"]}
                                    for job in restore_jobs]
            state_manager.push_state(
                {"backup_vault_restore": {"jobs": restore_jobs_to_dict}, "restore_in_progress": True})

        except Exception as e:
            raise e

    bucket = validate_bucket()
    backup_vault = validate_backup_vault(bucket=bucket)
    api_key = get_cos_api_key(bucket=bucket, backup_vault=backup_vault)
    recovery_range = get_latest_recovery_range(backup_vault=backup_vault, api_key=api_key)
    restore_job = initiate_restore(bucket=bucket, backup_vault=backup_vault,
                                   recovery_range=recovery_range, api_key=api_key)
    save_restore_job_in_db(restore_job=restore_job, bucket=bucket,
                           backup_vault=backup_vault, recovery_range=recovery_range)


bucket_restore_backup_vault()
