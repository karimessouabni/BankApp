package com.bnpp.app.service.dto.v1;

import com.fasterxml.jackson.dataformat.xml.XmlMapper;
import org.junit.jupiter.api.Test;

import java.io.InputStream;
import java.util.Objects;

import static org.assertj.core.api.Assertions.assertThat;

class BucketMultiPartUploadDTOTest {

    @Test
    void shouldDeserializeListMultipartUploadsXml() throws Exception {
        try (InputStream in = Objects.requireNonNull(
                getClass().getResourceAsStream("/list-multipart-uploads.xml"))) {

            BucketMultiPartUploadDTO dto = new XmlMapper()
                    .readValue(in, BucketMultiPartUploadDTO.class);

            assertThat(dto.getBucket()).isEqualTo("bu0021020570");
            assertThat(dto.getUploads()).hasSize(2);
            assertThat(dto.getUploads().get(0).getKey()).isEqualTo("mytestobject.bin");
            assertThat(dto.getUploads().get(0).getStorageClass()).isEqualTo("STANDARD");
        }
    }
}
